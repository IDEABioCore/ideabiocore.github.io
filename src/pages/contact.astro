---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';

const details = [
  {
    label: 'Email',
    value: 'ideabio@uq.edu.au',
    href: 'mailto:ideabio@uq.edu.au?subject=IDEA%20Bio%20enquiry',
    icon: 'mail',
  },
  {
    label: 'Find us',
    value: 'Building 75, Cnr College Rd & Cooper Rd, St Lucia QLD 4072, Australia',
    href: 'https://maps.google.com/?q=AIBN+Building+75+University+of+Queensland+St+Lucia',
    icon: 'pin',
  },
  {
    label: 'Follow',
    value: 'LinkedIn — @ideabio',
    href: 'https://www.linkedin.com/company/ideabio/',
    icon: 'link',
  },
];
---

<BaseLayout title="Contact · IDEA Bio" description="Get in touch with IDEA Bio at the AIBN, The University of Queensland — email ideabio@uq.edu.au.">
  <PageHero
    eyebrow="Contact"
    title="Get in touch"
    lead="Tell us what you want to make with biology — we'll help you design, test and scale it. We're based at the AIBN, The University of Queensland."
    image="/images/aibn-building-dusk.jpg"
    imageAlt="The AIBN building at dusk"
  >
    <a slot="actions" href="mailto:ideabio@uq.edu.au?subject=IDEA%20Bio%20enquiry" class="btn btn--primary">Email the team</a>
  </PageHero>

  <section class="section">
    <div class="container">
      <ul class="contact-grid">
        {details.map((d, i) => (
          <li data-reveal style={`transition-delay:${i * 80}ms`}>
            <a class="contact-card" href={d.href} target={d.icon === 'mail' ? undefined : '_blank'} rel="noopener">
              <span class="contact-ic" aria-hidden="true">
                {d.icon === 'mail' && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg>
                )}
                {d.icon === 'pin' && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M12 21s7-6.2 7-11a7 7 0 1 0-14 0c0 4.8 7 11 7 11z"/><circle cx="12" cy="10" r="2.5"/></svg>
                )}
                {d.icon === 'link' && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M10 14a5 5 0 0 0 7 0l3-3a5 5 0 0 0-7-7l-1 1"/><path d="M14 10a5 5 0 0 0-7 0l-3 3a5 5 0 0 0 7 7l1-1"/></svg>
                )}
              </span>
              <span class="contact-label">{d.label}</span>
              <span class="contact-value">{d.value}</span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(1.25rem, 2.5vw, 1.75rem);
    list-style: none;
    padding: 0;
  }
  .contact-card {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    height: 100%;
    padding: 1.9rem 1.7rem;
    background: var(--surface);
    border: 1px solid var(--hairline);
    border-radius: var(--radius);
    text-decoration: none;
    color: var(--ink);
    transition: transform .18s ease, border-color .18s ease, box-shadow .18s ease;
  }
  .contact-card:hover {
    transform: translateY(-4px);
    border-color: color-mix(in srgb, var(--accent) 45%, var(--hairline));
    box-shadow: var(--shadow-sm);
  }
  .contact-ic {
    display: grid; place-items: center;
    width: 44px; height: 44px;
    border-radius: 12px;
    background: color-mix(in srgb, var(--accent) 12%, transparent);
    color: var(--accent-text);
    margin-bottom: 0.4rem;
  }
  .contact-ic svg { width: 22px; height: 22px; }
  .contact-label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .contact-value { font-weight: 600; letter-spacing: -0.01em; line-height: 1.4; }

  @media (max-width: 820px) { .contact-grid { grid-template-columns: 1fr; } }
</style>
