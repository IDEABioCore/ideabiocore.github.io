---
// Shared inner-page hero — keeps every page consistent with the Home look
// (eyebrow + display heading + lead + optional image), the violet glow and the
// scroll-reveal treatment. Pass an "actions" slot for buttons.
interface Props {
  eyebrow: string;
  title: string;
  lead?: string;
  image?: string;
  imageAlt?: string;
}
const { eyebrow, title, lead, image, imageAlt = '' } = Astro.props;
const hasImage = Boolean(image);
---

<section class:list={['page-hero', { 'has-image': hasImage }]}>
  <div class="hero-glow" aria-hidden="true"></div>
  <div class="container ph-inner">
    <div class="ph-copy" data-reveal>
      <p class="eyebrow">{eyebrow}</p>
      <h1>{title}</h1>
      {lead && <p class="lead ph-lead">{lead}</p>}
      <div class="ph-actions"><slot name="actions" /></div>
    </div>

    {hasImage && (
      <figure class="ph-media" data-reveal>
        <img src={image} alt={imageAlt} width="900" height="640" loading="eager" fetchpriority="high" />
      </figure>
    )}
  </div>
</section>

<style>
  .page-hero {
    position: relative;
    overflow: clip;
    padding-block: clamp(48px, 7vw, 92px);
    background:
      radial-gradient(115% 85% at 85% 0%, color-mix(in srgb, var(--accent) 8%, transparent), transparent 58%),
      var(--bg);
    border-bottom: 1px solid var(--hairline);
  }
  .hero-glow {
    position: absolute;
    top: -30%; right: -8%;
    width: 46vw; height: 46vw;
    max-width: 620px; max-height: 620px;
    background: radial-gradient(circle, color-mix(in srgb, var(--accent) 14%, transparent), transparent 68%);
    filter: blur(28px);
    z-index: 0;
    pointer-events: none;
  }
  .ph-inner { position: relative; z-index: 1; }

  .page-hero.has-image .ph-inner {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
  }
  .ph-copy { max-width: 60ch; }
  .page-hero h1 { font-size: var(--step-4); margin-top: 1rem; }
  .ph-lead { margin-top: 1.25rem; max-width: 54ch; color: var(--muted); }
  .ph-actions:empty { display: none; }
  .ph-actions { display: flex; flex-wrap: wrap; gap: 0.85rem; margin-top: 1.9rem; }

  .ph-media { position: relative; margin: 0; }
  .ph-media img {
    width: 100%;
    aspect-ratio: 3 / 2;
    object-fit: cover;
    border-radius: var(--radius);
    box-shadow: var(--shadow);
  }
  .ph-media::before {
    content: "";
    position: absolute;
    inset: -1px;
    border-radius: calc(var(--radius) + 1px);
    padding: 1px;
    background: linear-gradient(150deg, color-mix(in srgb, var(--accent) 55%, transparent), transparent 45%);
    -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
  }

  @media (max-width: 900px) {
    .page-hero.has-image .ph-inner { grid-template-columns: 1fr; }
    .page-hero.has-image .ph-media { order: -1; }
  }
</style>
